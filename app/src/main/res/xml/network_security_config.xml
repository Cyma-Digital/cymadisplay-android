<?xml version="1.0" encoding="utf-8"?>
<!--
    Trusts system CAs plus a bundled copy of ISRG Root X1 (Let's Encrypt root).
    ISRG Root X1 was only added to the Android system trust store in 7.1.1
    (API 25). The backend (api.cymadisplay / www.cymadisplay.com) serves a
    Let's Encrypt cert chaining to ISRG Root X1, so on Android 5.0–7.0 the
    handshake fails with "Trust anchor for certification path not found"
    unless we bundle the root ourselves.

    On Android 7.1+ the bundled cert is redundant (system already has it).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="@raw/isrg_root_x1" />
        </trust-anchors>
    </base-config>
</network-security-config>
